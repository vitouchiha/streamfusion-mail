# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info   # debug | info | warn | error

# Timeouts (milliseconds)
CATALOG_TIMEOUT=9000
META_TIMEOUT=30000
STREAM_TIMEOUT=45000

# Cloudflare bypass (kisskh.co)
CF_COOKIE_MAX_AGE=3600000    # 1 hour
CF_MAX_RETRY=3
CF_RETRY_DELAY=5000          # base delay (exponential backoff applied)

# Puppeteer — @sparticuz/chromium gestisce il binary automaticamente su Vercel.
# Imposta solo se usi un Chromium custom (Docker/Linux con chromium pre-installato).
# Lascia vuoto per sviluppo locale (rileva Chrome di sistema).
PUPPETEER_EXECUTABLE_PATH=

# Proxy (RICHIESTO per Vercel/hosting cloud)
# kisskh.co e ramaorientalfansub.live bloccano gli IP datacenter AWS/Vercel con CF.
# Imposta un proxy residenziale per aggirare il blocco.
# Formati supportati:
#   http://user:pass@host:port
#   socks5://user:pass@host:port
# Provider consigliati:
#   - WebShare.io (piano free disponibile): https://proxy.webshare.io
#   - BrightData residential proxy (a pagamento)
#   - Proxy personale su VPS
PROXY_URL=

# Lista di proxy statici separati da virgola (opzionale, per smart rotation)
WEBSHARE_PROXIES=

# Cloudflare Worker — proxy per KissKH, EuroStreaming, uprot KV, AnimeUnity search
CF_WORKER_URL=
CF_WORKER_AUTH=
CF_PROXY_URL=

# TMDB API key (v3, gratuita su https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Browserless.io — Chrome remoto per Cloudflare bypass (opzionale)
# Formato: wss://production-sfo.browserless.io?token=YOUR_TOKEN
BROWSERLESS_URL=

# MediaFlow Proxy — per ToonItalia HLS streaming (opzionale)
MFP_URL=
MFP_API_PASSWORD=

# FlareSolverr — CF bypass alternativo (opzionale)
FLARESOLVERR_URL=

# Sicurezza
CONFIG_SECRET=                 # Segreto per cifratura config utente (CAMBIARE in produzione!)
HLS_PROXY_SECRET=              # Segreto HMAC per HLS proxy token (CAMBIARE in produzione!)
CRON_SECRET=                   # Segreto per endpoint cron
DEBUG_TOKEN=                   # Token per endpoint /debug-stream/

# Avanzate
CF_CLEARANCE_KISSKH=           # Cookie CF clearance per KissKH (opzionale)
HLS_PROXY_TIMEOUT=             # Timeout HLS proxy in ms (default: 10000)
SERVERLESS_TIMEOUT=            # Timeout funzione serverless in ms (default: 55000)
