{
  "version": 2,
  "regions": ["fra1"],
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 60, "includeFiles": ["es-cache/**", "es-titles-index.json"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
