# ── StreamFusion Mail — WireGuard + Environment Config EXAMPLE ──────────────
# Copia questo file in stack.env e compila con le tue credenziali reali.
# Uso: docker compose --env-file stack.env up -d

# ── WireGuard VPN (Gluetun) ───────────────────────────────────────────────────
VPN_ENDPOINT_IP=
VPN_ENDPOINT_PORT=51820
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
WIREGUARD_DNS=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_PRESHARED_KEY=

# ── Proxy HTTP (gost) — credenziali per autenticazione ───────────────────────
# Usati per proteggere il proxy esposto su internet
# Imposta la stessa password in Vercel: PROXY_URL=http://USER:PASS@TUO_IP:8118
PROXY_USER=sfmail
PROXY_PASS=
